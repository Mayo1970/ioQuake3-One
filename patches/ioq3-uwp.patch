 		}
 	}
 
+#ifdef IOQ3_UWP
+	if ( uwp_in_ui )
+	{
+		// Left stick -> mouse cursor (deadzone + squared response + sub-pixel accumulation).
+		static float uwp_cursor_x = 0.0f;
+		static float uwp_cursor_y = 0.0f;
+		const float UWP_MENU_CURSOR_SPEED = 8.0f;
+		const int   UWP_STICK_DEADZONE    = 8000;
+
+		int sx = SDL_GameControllerGetAxis( gamepad, SDL_CONTROLLER_AXIS_LEFTX );
+		int sy = SDL_GameControllerGetAxis( gamepad, SDL_CONTROLLER_AXIS_LEFTY );
+
+		if ( sx > -UWP_STICK_DEADZONE && sx < UWP_STICK_DEADZONE ) sx = 0;

+
+		if ( sx != 0 || sy != 0 )
+		{
+			float fx = (float)sx / 32767.0f;
+			float fy = (float)sy / 32767.0f;
+			float ax = fx * fx * UWP_MENU_CURSOR_SPEED;
+			float ay = fy * fy * UWP_MENU_CURSOR_SPEED;
+			if ( fx < 0.0f ) ax = -ax;
+			if ( fy < 0.0f ) ay = -ay;
+
+			uwp_cursor_x += ax;
+			uwp_cursor_y += ay;
+
+			int dx = (int)uwp_cursor_x;
+			int dy = (int)uwp_cursor_y;

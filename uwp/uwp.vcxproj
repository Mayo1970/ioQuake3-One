  <!-- ================================================================
       ANGLE DLLs — replaces Mesa opengl32.dll / libgallium_wgl.dll
       libEGL.dll   : EGL context/surface management (→ D3D11 SwapChain)
       libGLESv2.dll: OpenGL ES 2.0 implementation (→ D3D11 draw calls)
       d3dcompiler_47.dll: runtime HLSL compilation for ANGLE shaders
       ================================================================ -->
  <ItemGroup>
    <Content Include="$(ANGLE_BIN_DIR)\libEGL.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Content Include="$(ANGLE_BIN_DIR)\libGLESv2.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <!--
    d3dcompiler_47.dll ships with the Windows SDK and must be included in
    the package because Xbox Dev Mode does not guarantee it is present.
    Typical location: C:\Windows\System32\d3dcompiler_47.dll
    OR: $(WindowsSdkDir)Redist\D3D\x64\d3dcompiler_47.dll
  -->
  <ItemGroup>
    <Content Include="$(WindowsSdkDir)Redist\D3D\x64\d3dcompiler_47.dll">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>


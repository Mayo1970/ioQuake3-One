# ============================================================================
# ioQ3-One — repository ignore rules
# ============================================================================
# Keep only what's needed to reproduce a working build:
#   - UWP shell source (uwp/, libuwp/)
#   - Patches against the ioq3 + SDL-uwp-gl trees (patches/)
#   - Project metadata (sln, README, LICENSE, CLAUDE.md is excluded below)
# Everything else — retail data, third-party sources, build outputs, signed
# bundles — is excluded. Built artifacts ship via the GitHub Releases tab.
# ============================================================================

# ----------------------------------------------------------------------------
# Claude Code / agent state
# ----------------------------------------------------------------------------
.claude/
CLAUDE.md
memory/
MEMORY.md
*.claude.md

# ----------------------------------------------------------------------------
# Quake III Arena retail data (NOT redistributable — user supplies their own)
# ----------------------------------------------------------------------------
**/baseq3/pak*.pk3
**/baseq3/*.pk3
**/baseq3/q3config.cfg
**/baseq3/*.cfg
!data/xbone-autoexec.cfg
*.pk3
demoq3/
missionpack/

# ----------------------------------------------------------------------------
# Build outputs — UWP / MSBuild
# ----------------------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
bld/
.vs/
Generated\ Files/
BundleArtifacts/
AppPackages/
AppPackages2/
*.appx
*.appxbundle
*.appxupload
*.msix
*.msixbundle
*.msixupload
Package.StoreAssociation.xml
_pkginfo.txt

# ----------------------------------------------------------------------------
# Build outputs — ioq3 MinGW CMake tree
# ----------------------------------------------------------------------------
ioq3/build/
ioq3/Makefile
ioq3/CMakeCache.txt
ioq3/CMakeFiles/
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
*.def
*.dll
*.lib
*.exp
*.exe
*.so
*.dylib
*.qvm

# ----------------------------------------------------------------------------
# Third-party trees (cloned/downloaded — not part of this repo)
# ----------------------------------------------------------------------------
# The ioq3 engine source is cloned separately and patched via patches/
ioq3/
# Series S/X port — read-only reference, not shipped here
ioq3-uwp/
# aerisarn's SDL-uwp-gl clone — patched via patches/sdl-uwp-gl.patch
SDL-uwp-gl/
# RetroArch ANGLE drop (headers + prebuilt x64 UWP DLLs)
dev\ stuff/
dev stuff/

# ----------------------------------------------------------------------------
# Crash dumps / runtime artifacts
# ----------------------------------------------------------------------------
Crash\ dumps/
Crash dumps/
*.dmp
*.mdmp
ioq3_error.log
qconsole.log
boot_*.log
sdlbc_*.log


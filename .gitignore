# ============================================================================
# ioQ3-One — repository ignore rules
# ============================================================================
# Keep everything needed to reproduce a working build:
#   - UWP shell source (uwp/, libuwp/)
#   - ioquake3 engine source + CMake tree (code/, cmake/, CMakeLists.txt)
#   - Bundled third-party dependency sources & prebuilt link libs
#     (code/thirdparty/) — REQUIRED by the CMake configure step
#   - Project metadata (sln, README, LICENSE, data/)
# Excluded: retail game data, build outputs, signed bundles, IDE/OS junk.
# Built artifacts ship via the GitHub Releases tab.
# ============================================================================

# ----------------------------------------------------------------------------
# Claude Code / agent state
# ----------------------------------------------------------------------------
.claude/
CLAUDE.md
AGENTS.md
memory/
MEMORY.md
*.claude.md

# ----------------------------------------------------------------------------
# Quake III Arena retail data (NOT redistributable — user supplies their own)
# ----------------------------------------------------------------------------
**/baseq3/pak*.pk3
**/baseq3/*.pk3
**/baseq3/q3config.cfg
**/baseq3/*.cfg
!data/xbone-autoexec.cfg
*.pk3
demoq3/
missionpack/

# ----------------------------------------------------------------------------
# Build outputs — CMake / MinGW tree
# ----------------------------------------------------------------------------
# The whole out-of-source CMake build dir (49M of generated Makefiles,
# stringified shaders, QVM intermediates, ExternalProject stamps, artifacts).
/build/
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake

# ----------------------------------------------------------------------------
# Build outputs — UWP / MSBuild
# ----------------------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
bld/
.vs/
Generated\ Files/
BundleArtifacts/
AppPackages/
AppPackages2/
*.appx
*.appxbundle
*.appxupload
*.msix
*.msixbundle
*.msixupload
Package.StoreAssociation.xml
_pkginfo.txt

# ----------------------------------------------------------------------------
# Compiled / generated binaries
# ----------------------------------------------------------------------------
# Blanket-ignore build artifacts, but force-keep the prebuilt third-party
# link libraries the build links against (these are checked-in dependencies,
# not build output). See cmake/libraries/sdl.cmake.
*.def
*.dll
*.lib
*.exp
*.so
*.dylib
*.qvm
*.a
!code/thirdparty/libs/**

# ----------------------------------------------------------------------------
# Crash dumps / runtime logs
# ----------------------------------------------------------------------------
Crash\ dumps/
Crash dumps/
*.dmp
*.mdmp
ioq3_error.log
qconsole.log
boot_*.log
sdlbc_*.log

# ----------------------------------------------------------------------------
# Visual Studio / MSVC scratch
# ----------------------------------------------------------------------------
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.opendb
*.VC.db
*.VC.VC.opendb
*.ilk
*.iobj
*.ipdb
*.pdb
*.pch
*.obj
*.tlog
*.log
*.tmp
*.tlb
*.tli
*.tlh
*.aps
*.ncb
*.sdf
*.cachefile
*.[Cc]ache
!?*.[Cc]ache/

# ----------------------------------------------------------------------------
# Signing — keep the temp pfx so anyone can do a test build, but never commit
# a real publisher cert.
# ----------------------------------------------------------------------------
*.pfx
!uwp/uwp_TemporaryKey.pfx

# ----------------------------------------------------------------------------
# Editor / OS junk
# ----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
.localhistory/
.vshistory/
*.code-workspace
*~
~$*
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----------------------------------------------------------------------------
# Misc — anything that doesn't contribute to a running build
# ----------------------------------------------------------------------------
*.binlog
*.publishsettings
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
